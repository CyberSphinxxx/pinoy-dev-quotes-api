{
  "name": "pinoy-dev-quotes-api",
  "version": "1.0.0",
  "description": "A free, serverless API for Filipino developer quotes.",
  "main": "api/index.js",
  "scripts": {
    "dev": "node api/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "start": "node api/index.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.2",
    "graphql-http": "^1.22.4",
    "helmet": "^8.1.0",
    "satori": "^0.26.0"
  },
  "keywords": [
    "pinoy",
    "dev",
    "quotes",
    "api",
    "serverless",
    "vercel",
    "bisaya",
    "tagalog"
  ],
  "author": "John Lemar Gonzales",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
