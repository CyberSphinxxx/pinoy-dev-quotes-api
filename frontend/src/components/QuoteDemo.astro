---
import EndpointCard from './EndpointCard.astro';

interface Endpoint {
  method: 'GET' | 'POST';
  path: string;
  description: string;
  isXml?: boolean;
}

interface EndpointGroup {
  group: string;
  items: Endpoint[];
}

const endpoints: EndpointGroup[] = [
  { group: 'Core', items: [
    { method: 'GET', path: '/api/v1', description: 'API Index & Snippets' },
    { method: 'GET', path: '/api/v1/random', description: 'Random quote (add ?count=3 for multiple)' },
    { method: 'GET', path: '/api/v1/qotd', description: 'Quote of the Day' },
    { method: 'GET', path: '/api/v1/quotes?page=1&limit=5', description: 'Paginated list' },
    { method: 'GET', path: '/api/v1/quotes/1', description: 'Get by ID' },
    { method: 'GET', path: '/api/v1/search?q=bug', description: 'Search quotes' }
  ]},
  { group: 'Dialects', items: [
    { method: 'GET', path: '/api/v1/dialects', description: 'List all dialects' },
    { method: 'GET', path: '/api/v1/dialect/bisaya', description: 'Filter by dialect' },
    { method: 'GET', path: '/api/v1/dialect/tagalog/random', description: 'Random from dialect' }
  ]},
  { group: 'Advanced', items: [
    { method: 'GET', path: '/api/v1/stats', description: 'API statistics' },
    { method: 'GET', path: '/api/v1/embed', description: 'Embeddable widget snippet' },
    { method: 'GET', path: '/api/v1/cors-check', description: 'CORS configuration' },
    { method: 'GET', path: '/api/v1/quotes/1/image', description: 'Generate OG card (PNG)' },
    { method: 'GET', path: '/api/v1/feed.xml', description: 'RSS feed', isXml: true },
    { method: 'GET', path: '/api/health', description: 'Health check' }
  ]}
];
---
<section id="playground" class="playground">
  <div class="sidebar">
    {endpoints.map(group => (
      <>
        <div class="section-label">{group.group}</div>
        {group.items.map(item => (
          <EndpointCard method={item.method} path={item.path} description={item.description} data-xml={item.isXml} />
        ))}
      </>
    ))}

    <div class="section-label">Authentication</div>
    <div class="auth-box">
      <p><strong>Tiered Rate Limits</strong></p>
      <ul>
        <li>Public: <strong>100 req / 15m</strong></li>
        <li>Premium: <strong>1,000 req / 15m</strong></li>
      </ul>
      <p class="auth-note">Include your key via <code>Authorization: Bearer ...</code></p>
      <input type="text" id="api-key-input" placeholder="Optional API Key..." />
      <p class="auth-request">Need a key? <a href="https://github.com/CyberSphinxxx/pinoy-dev-quotes-api/issues" target="_blank">Open an issue</a> to request one.</p>
    </div>
  </div>

  <div class="terminal">
    <div class="terminal-header">
      <div class="dots"><span class="red"></span><span class="yellow"></span><span class="green"></span></div>
      <div class="terminal-url" id="terminal-url">Click an endpoint to begin →</div>
      <div class="terminal-spacer"></div>
    </div>
    <div class="terminal-body">
      <div class="spinner" id="spinner">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle opacity="0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path opacity="0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      </div>
      <pre id="response-viewer"><code>{`{
  "message": "Welcome! Click any endpoint on the left.",
  "tip": "Try /api/v1/random first 🎲"
}`}</code></pre>
      <div id="image-viewer-container" style="display: none;">
         <img id="image-viewer" alt="Generated Quote Image"/>
      </div>
    </div>
  </div>
</section>

<style>
  .playground {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 24px;
    margin-top: 48px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .playground { grid-template-columns: 1fr; }
  }
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .auth-box {
    padding: 16px;
    background: rgba(251, 191, 36, 0.05);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: var(--radius);
    font-size: 11px;
    color: var(--text-secondary);
  }
  .auth-box p { margin-bottom: 8px; }
  .auth-box strong { color: var(--amber); }
  .auth-box ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .auth-note { margin-top: 8px; color: var(--text-muted); }
  .auth-request { margin-top: 12px; font-size: 10px; color: var(--text-muted); }
  .auth-request a { color: var(--brand-400); text-decoration: none; }
  .auth-request a:hover { text-decoration: underline; }
  #api-key-input {
    width: 100%;
    background: var(--bg-terminal);
    border: 1px solid var(--glass-border);
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 11px;
    color: var(--brand-400);
    font-family: 'Fira Code', monospace;
    outline: none;
    transition: border-color 0.2s;
    margin-top: 8px;
  }
  #api-key-input:focus { border-color: var(--brand-400); }

  .terminal {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 500px;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    position: sticky;
    top: 100px;
  }
  .terminal-header {
    background: rgba(15, 23, 42, 0.8);
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .dots { display: flex; gap: 8px; }
  .dots span { width: 12px; height: 12px; border-radius: 50%; }
  .dots .red { background: var(--rose); opacity: 0.7; }
  .dots .yellow { background: var(--amber); opacity: 0.7; }
  .dots .green { background: var(--emerald); opacity: 0.7; }
  .terminal-url { font-family: 'Fira Code', monospace; font-size: 12px; color: var(--text-muted); }
  .terminal-spacer { width: 60px; }
  .terminal-body {
    background: var(--bg-terminal);
    flex: 1;
    padding: 24px;
    position: relative;
    overflow: auto;
  }
  #response-viewer {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--text-secondary);
  }
  #image-viewer-container {
    display: none;
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
  }
  #image-viewer {
    width: 100%;
    display: block;
  }
  .spinner {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    z-index: 10;
  }
  .spinner.show { display: flex; }
  .spinner svg { width: 32px; height: 32px; animation: spin 0.8s linear infinite; color: var(--brand-400); }
  @keyframes spin { to { transform: rotate(360deg); } }

  :global(.syn-key) { color: #c792ea; }
  :global(.syn-str) { color: #c3e88d; }
  :global(.syn-num) { color: #f78c6c; }
  :global(.syn-bool) { color: #ffcb6b; }
  :global(.syn-null) { color: #ff5370; }
</style>

<script>
  const highlight = (json: any) => {
    if (typeof json !== 'string') json = JSON.stringify(json, null, 2);
    return json
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/("(\\u[\da-fA-F]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, (m: string) => {
        let c = 'syn-num';
        if (/^"/.test(m)) c = /:$/.test(m) ? 'syn-key' : 'syn-str';
        else if (/true|false/.test(m)) c = 'syn-bool';
        else if (/null/.test(m)) c = 'syn-null';
        return `<span class="${c}">${m}</span>`;
      });
  };

  const buttons = document.querySelectorAll('.endpoint-btn');
  const spinner = document.getElementById('spinner');
  const viewer = document.getElementById('response-viewer');
  const imgViewer = document.getElementById('image-viewer') as HTMLImageElement | null;
  const terminalUrl = document.getElementById('terminal-url');
  const apiKeyInput = document.getElementById('api-key-input') as HTMLInputElement | null;

  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      // Toggle active state
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const path = btn.getAttribute('data-path');
      const method = btn.getAttribute('data-method');
      const isXml = btn.hasAttribute('data-xml');
      
      if (!path || !method || !spinner || !viewer || !terminalUrl) return;

      const isImage = path.endsWith('/image');
      const apiKey = apiKeyInput?.value.trim() || '';

      spinner.classList.add('show');
      if (imgViewer) imgViewer.style.display = 'none';
      viewer.style.display = 'block';

      let finalPath = path;
      const headers: Record<string, string> = {};
      if (apiKey) {
        headers['Authorization'] = `Bearer ${apiKey}`;
        finalPath += (path.includes('?') ? '&' : '?') + 'api_key=' + apiKey;
      }

      terminalUrl.textContent = `${method} ${finalPath}`;

      try {
        const response = await fetch(path, { headers });
        if (isImage && imgViewer) {
          const blob = await response.blob();
          viewer.style.display = 'none';
          imgViewer.src = URL.createObjectURL(blob);
          const container = document.getElementById('image-viewer-container');
          if (container) container.style.display = 'block';
        } else if (isXml) {
          const text = await response.text();
          viewer.textContent = text;
        } else {
          const data = await response.json();
          viewer.innerHTML = highlight(data);
        }
      } catch (err: any) {
        viewer.innerHTML = `<span class="syn-null">Error: ${err.message}</span>`;
      } finally {
        spinner.classList.remove('show');
      }
    });
  });
</script>
