---
/**
 * OWNS: Interactive API Playground Component
 * DO: Handle user interactions with the API demonstration.
 * DON'T: Perform raw fetch calls or hardcode API URLs. Use ApiClient and constants.
 */

import EndpointCard from './EndpointCard.astro';
import { API_CONFIG } from '../lib/constants';

interface Endpoint {
  method: 'GET' | 'POST';
  path: string;
  description: string;
  isXml?: boolean;
}

interface EndpointGroup {
  group: string;
  items: Endpoint[];
}

const endpoints: EndpointGroup[] = [
  { group: 'Core', items: [
    { method: 'GET', path: '/api/v1', description: 'API Index & Snippets' },
    { method: 'GET', path: '/api/v1/random', description: 'Random quote (add ?count=3 for multiple)' },
    { method: 'GET', path: '/api/v1/qotd', description: 'Quote of the Day' },
    { method: 'GET', path: '/api/v1/quotes?page=1&limit=5', description: 'Paginated list' },
    { method: 'GET', path: '/api/v1/quotes/1', description: 'Get by ID' },
    { method: 'GET', path: '/api/v1/search?q=bug', description: 'Search quotes' }
  ]},
  { group: 'Dialects', items: [
    { method: 'GET', path: '/api/v1/dialects', description: 'List all dialects' },
    { method: 'GET', path: '/api/v1/dialect/bisaya', description: 'Filter by dialect' },
    { method: 'GET', path: '/api/v1/dialect/tagalog/random', description: 'Random from dialect' }
  ]},
  { group: 'Advanced', items: [
    { method: 'GET', path: '/api/v1/stats', description: 'API statistics' },
    { method: 'GET', path: '/api/v1/embed', description: 'Embeddable widget snippet' },
    { method: 'GET', path: '/api/v1/cors-check', description: 'CORS configuration' },
    { method: 'GET', path: '/api/v1/quotes/1/image', description: 'Generate OG card (PNG)' },
    { method: 'GET', path: '/api/v1/feed.xml', description: 'RSS feed', isXml: true },
    { method: 'GET', path: '/api/health', description: 'Health check' }
  ]}
];
---
<section id="playground" class="playground">
  <div class="sidebar">
    {endpoints.map(group => (
      <>
        <div class="section-label">{group.group}</div>
        {group.items.map(item => (
          <EndpointCard method={item.method} path={item.path} description={item.description} data-xml={item.isXml} />
        ))}
      </>
    ))}

    <div class="section-label">Authentication</div>
    <div class="auth-box">
      <p><strong>Tiered Rate Limits</strong></p>
      <ul>
        <li>Public: <strong>100 req / 15m</strong></li>
        <li>Premium: <strong>1,000 req / 15m</strong></li>
      </ul>
      <p class="auth-note">Include your key via <code>Authorization: Bearer ...</code> header. Query parameters are discouraged for security.</p>
      <input type="text" id="api-key-input" placeholder="Optional API Key..." />
      <p class="auth-request">Need a key? <a href={API_CONFIG.TICKET_URL} target="_blank">Request a free Premium Key</a> to increase your rate limits.</p>
    </div>
  </div>

  <div class="terminal">
    <div class="terminal-header">
      <div class="dots"><span class="red"></span><span class="yellow"></span><span class="green"></span></div>
      <div class="terminal-url" id="terminal-url">Click an endpoint to begin →</div>
      <div class="terminal-spacer"></div>
    </div>
    <div class="terminal-body">
      <div class="spinner" id="spinner">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle opacity="0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path opacity="0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      </div>
      <pre id="response-viewer"><code>{`{
  "message": "Welcome! Click any endpoint on the left.",
  "tip": "Try /api/v1/random first 🎲"
}`}</code></pre>
      <div id="image-viewer-container" style="display: none;">
         <img id="image-viewer" alt="Generated Quote Image"/>
      </div>
    </div>
  </div>
</section>

<style>
  .playground {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-6);
    margin-top: var(--space-12);
    align-items: start;
  }
  @media (max-width: 900px) {
    .playground { grid-template-columns: 1fr; }
  }
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .auth-box {
    padding: var(--space-4);
    background: rgba(251, 191, 36, 0.05);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }
  .auth-box p { margin-bottom: var(--space-2); }
  .auth-box strong { color: var(--color-warning); }
  .auth-box ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .auth-note { margin-top: var(--space-2); color: var(--color-text-muted); }
  .auth-request { margin-top: var(--space-3); font-size: 10px; color: var(--color-text-muted); }
  .auth-request a { color: var(--color-brand-muted); text-decoration: none; }
  .auth-request a:hover { text-decoration: underline; }
  #api-key-input {
    width: 100%;
    background: var(--color-bg-terminal);
    border: 1px solid var(--color-glass-border);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: var(--color-brand-muted);
    font-family: 'Fira Code', monospace;
    outline: none;
    transition: border-color var(--duration-fast);
    margin-top: var(--space-2);
  }
  #api-key-input:focus { border-color: var(--color-brand-muted); }

  .terminal {
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 500px;
    box-shadow: var(--shadow-2xl);
    position: sticky;
    top: 100px;
  }
  .terminal-header {
    background: rgba(15, 23, 42, 0.8);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border-muted);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .dots { display: flex; gap: 8px; }
  .dots span { width: 12px; height: 12px; border-radius: 50%; }
  .dots .red { background: var(--color-danger); opacity: 0.7; }
  .dots .yellow { background: var(--color-warning); opacity: 0.7; }
  .dots .green { background: var(--color-success); opacity: 0.7; }
  .terminal-url { font-family: 'Fira Code', monospace; font-size: var(--font-size-sm); color: var(--color-text-muted); }
  .terminal-spacer { width: 60px; }
  .terminal-body {
    background: var(--color-bg-terminal);
    flex: 1;
    padding: var(--space-6);
    position: relative;
    overflow: auto;
  }
  #response-viewer {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--color-text-secondary);
  }
  #image-viewer-container {
    display: none;
    width: 100%;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-glass-border);
    overflow: hidden;
  }
  #image-viewer {
    width: 100%;
    display: block;
  }
  .spinner {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    z-index: 10;
  }
  .spinner.show { display: flex; }
  .spinner svg { width: 32px; height: 32px; animation: spin 0.8s linear infinite; color: var(--color-brand-muted); }
  @keyframes spin { to { transform: rotate(360deg); } }

  :global(.syn-key) { color: var(--color-syn-key); }
  :global(.syn-str) { color: var(--color-syn-str); }
  :global(.syn-num) { color: var(--color-syn-num); }
  :global(.syn-bool) { color: var(--color-syn-bool); }
  :global(.syn-null) { color: var(--color-syn-null); }
</style>

<script>
  import { ApiClient } from '../lib/api';
  import { highlightJson } from '../lib/utils';

  const buttons = document.querySelectorAll('.endpoint-btn');
  const spinner = document.getElementById('spinner');
  const viewer = document.getElementById('response-viewer');
  const imgViewer = document.getElementById('image-viewer') as HTMLImageElement | null;
  const terminalUrl = document.getElementById('terminal-url');
  const apiKeyInput = document.getElementById('api-key-input') as HTMLInputElement | null;

  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      // Toggle active state
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const path = btn.getAttribute('data-path');
      const method = btn.getAttribute('data-method');
      const isXml = btn.hasAttribute('data-xml');
      
      if (!path || !method || !spinner || !viewer || !terminalUrl) return;

      const isImage = path.endsWith('/image');
      const apiKey = apiKeyInput?.value.trim() || '';

      spinner.classList.add('show');
      if (imgViewer) imgViewer.style.display = 'none';
      viewer.style.display = 'block';

      terminalUrl.textContent = `${method} ${path}`;

      try {
        const response = await ApiClient.fetchEndpoint(path, method, apiKey);
        
        if (isImage && imgViewer) {
          viewer.style.display = 'none';
          imgViewer.src = URL.createObjectURL(response as Blob);
          imgViewer.style.display = 'block'; // Ensure image is visible
          const container = document.getElementById('image-viewer-container');
          if (container) container.style.display = 'block';
        } else if (isXml) {
          viewer.textContent = response as string;
        } else {
          viewer.innerHTML = highlightJson(response);
        }
      } catch (err: any) {
        viewer.innerHTML = `<span class="syn-null">Error: ${err.message}</span>`;
      } finally {
        spinner.classList.remove('show');
      }
    });
  });
</script>
