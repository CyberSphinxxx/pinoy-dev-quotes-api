---
/**
 * OWNS: Application Footer
 * DO: Add copyright information and global external links.
 * DON'T: Add navigation links that belong in the Navbar.
 */
---
<footer class="footer">
  <div class="container footer-content">
    <div class="footer-copy">
      Built with ❤️ for Filipino Developers 🇵🇭
    </div>
    <div class="footer-links">
      <a href="https://github.com/CyberSphinxxx/pinoy-dev-quotes-api" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="divider">|</span>
      <a href="/openapi.json" target="_blank">OpenAPI Spec (JSON)</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-glass-border);
    margin-top: var(--space-24);
    background: rgba(15, 23, 42, 0.4);
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    text-align: center;
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }
  .footer-links {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }
  .footer-links a {
    color: var(--color-brand-muted);
    text-decoration: none;
    transition: color var(--duration-base);
  }
  .footer-links a:hover {
    color: var(--color-text-primary);
  }
  .divider {
    color: var(--color-glass-border);
  }
</style>
