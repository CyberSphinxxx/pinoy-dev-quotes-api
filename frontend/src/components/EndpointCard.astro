---
/**
 * OWNS: API Endpoint Selection Button
 * DO: Display a clickable card representing an API endpoint.
 * DON'T: Handle the actual fetching logic here. Use QuoteDemo.
 */

export interface Props {
  method: 'GET' | 'POST';
  path: string;
  description: string;
}

const { method, path, description } = Astro.props;
---
<button class="endpoint-btn" data-path={path} data-method={method}>
  <span class={`method-badge method-${method.toLowerCase()}`}>{method}</span>
  <div class="endpoint-info">
    <div class="endpoint-path">{path}</div>
    <div class="endpoint-desc">{description}</div>
  </div>
</button>

<style>
  .endpoint-btn {
    width: 100%;
    text-align: left;
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-base);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-primary);
    font-family: inherit;
    margin-bottom: var(--space-2);
  }
  .endpoint-btn:hover {
    transform: translateY(-2px);
    border-color: var(--color-brand-muted);
    box-shadow: var(--shadow-xl);
  }
  .endpoint-btn.active {
    border-color: var(--color-brand-primary);
    background: rgba(14, 165, 233, 0.08);
  }
  .method-badge {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .method-get {
    background: rgba(52, 211, 153, 0.15);
    color: var(--color-success);
    border: 1px solid rgba(52, 211, 153, 0.3);
  }
  .method-post {
    background: rgba(251, 191, 36, 0.15);
    color: var(--color-warning);
    border: 1px solid rgba(251, 191, 36, 0.3);
  }
  .endpoint-path {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    color: var(--color-text-primary);
  }
  .endpoint-desc {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: 2px;
  }
</style>
