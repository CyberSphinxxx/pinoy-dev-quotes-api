---
/**
 * OWNS: Code Snippet Card
 * DO: Display formatted code blocks with a copy-to-clipboard feature.
 * DON'T: Add heavy syntax highlighting logic here (use a library if needed).
 */

export interface Props {
  lang: string;
  code: string;
}

const { lang, code } = Astro.props;
---
<div class="snippet-card">
  <div class="snippet-card-header">
    <span class="snippet-lang">{lang}</span>
    <button class="snippet-copy" data-code={code}>Copy</button>
  </div>
  <pre><code>{code}</code></pre>
</div>

<style>
  .snippet-card {
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .snippet-card-header {
    padding: var(--space-3) var(--space-4);
    background: rgba(15, 23, 42, 0.6);
    border-bottom: 1px solid var(--color-glass-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .snippet-lang {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--color-brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .snippet-copy {
    background: none;
    border: 1px solid var(--color-glass-border);
    color: var(--color-text-muted);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    cursor: pointer;
    font-family: inherit;
    transition: all var(--duration-base);
  }
  .snippet-copy:hover {
    border-color: var(--color-brand-muted);
    color: var(--color-brand-muted);
  }
  .snippet-card pre {
    padding: var(--space-4);
    margin: 0;
    font-family: 'Fira Code', monospace;
    font-size: var(--font-size-sm);
    line-height: 1.7;
    color: var(--color-text-secondary);
    overflow-x: auto;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.snippet-copy');
  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (code) {
        await navigator.clipboard.writeText(code);
        const originalText = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
