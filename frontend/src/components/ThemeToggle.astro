---
/**
 * OWNS: Theme Toggle Component
 * DO: Add UI and scripts to toggle the theme.
 * DON'T: Re-implement theme logic here. Import ThemeManager.
 */
---

<button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme">
  <svg class="sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M3 12h2.25m.386-6.364 1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12a6.75 6.75 0 1 1 13.5 0 6.75 6.75 0 0 1-13.5 0Z" />
  </svg>
  <svg class="moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.724 9.724 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
  </svg>
</button>

<style>
  .theme-toggle {
    background: var(--color-glass-bg);
    border: 1px solid var(--color-glass-border);
    padding: 8px;
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: all var(--duration-base) var(--ease-in-out);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-toggle:hover {
    border-color: var(--color-brand-primary);
    background: var(--color-border-muted);
  }

  .theme-toggle svg {
    width: 20px;
    height: 20px;
  }

  /* Theme-specific visibility */
  .sun { display: none; }
  .moon { display: block; }

  :global([data-theme="light"]) .sun { display: block; }
  :global([data-theme="light"]) .moon { display: none; }
</style>

<script>
  import { ThemeManager } from '../lib/theme';

  const toggle = document.getElementById('theme-toggle');
  
  if (toggle) {
    toggle.addEventListener('click', () => {
      ThemeManager.toggle();
    });
  }
</script>
