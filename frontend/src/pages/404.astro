---
/**
 * OWNS: 404 Error Page
 * DO: Display a friendly error message for missing routes.
 * DON'T: Add heavy redirect logic here.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Not Found">
  <div class="error-container">
    <div class="error-content">
      <div class="error-code">404</div>
      <h1 class="error-title">Quote Not Found</h1>
      <p class="error-message">This page might have been DELETED from production, or it's a bug we haven't fixed yet.</p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">Back to Home</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .error-code {
    font-size: 8rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-brand-muted), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-4);
    opacity: 0.8;
  }
  .error-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: var(--space-4);
  }
  .error-message {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 400px;
    margin: 0 auto var(--space-12);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--duration-base);
  }
  .btn-primary {
    background: var(--color-brand-primary);
    color: var(--color-white);
    box-shadow: 0 4px 14px 0 rgba(14, 165, 233, 0.39);
  }
  .btn-primary:hover {
    background: var(--color-brand-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(14, 165, 233, 0.23);
  }
</style>
