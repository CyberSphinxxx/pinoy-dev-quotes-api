---
/**
 * OWNS: Project Changelog Page
 * DO: List version history and key updates.
 * DON'T: Add detailed technical implementation notes.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Changelog" description="Changelog for Pinoy Dev Quotes API.">
  <div class="container changelog-page">
    <header class="page-header">
      <h1 class="page-title">Changelog</h1>
      <p class="page-subtitle">Track updates, improvements, and fixes to the Pinoy Dev Quotes API.</p>
    </header>

    <div class="changelog-timeline">
      <div class="timeline-item">
        <div class="timeline-date">April 5, 2026</div>
        <div class="timeline-content">
          <h2>v1.1.0 — Astro Refactor</h2>
          <ul>
            <li>Refactored the frontend to <strong>Astro</strong> for better performance and component structure.</li>
            <li>Introduced a new interactive playground for live API testing.</li>
            <li>Redesigned the UI for a more modern, dark-themed experience.</li>
            <li>Improved site navigation and added placeholder pages for documentation and changelog.</li>
            <li>Added a <code>data/</code> directory for the quotes JSON to separate data from the backend logic.</li>
          </ul>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-date">January 1, 2026</div>
        <div class="timeline-content">
          <h2>v1.0.0 — Initial Release</h2>
          <ul>
            <li>Lunched the first version of the API with 20 quotes in 7 dialects.</li>
            <li>Supported basic REST endpoints for random quotes and searching.</li>
            <li>Deployed as serverless functions on Vercel.</li>
            <li>Included basic Swagger/OpenAPI documentation.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .changelog-page {
    padding: var(--space-24) var(--space-6);
    max-width: 800px;
  }
  .page-header {
    margin-bottom: var(--space-16);
    text-align: center;
  }
  .page-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }
  .page-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
  }
  .changelog-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    border-left: 1px solid var(--color-glass-border);
    padding-left: var(--space-8);
    margin-left: var(--space-4);
  }
  .timeline-item {
    position: relative;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -37px;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand-primary);
    border: 4px solid var(--color-bg-primary);
  }
  .timeline-date {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .timeline-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }
  .timeline-content ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .timeline-content li {
    position: relative;
    color: var(--color-text-secondary);
    padding-left: var(--space-6);
  }
  .timeline-content li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-brand-muted);
  }
</style>
